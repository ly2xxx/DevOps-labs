# UBI9-Minimal Coder Template with Claude Code Pre-installed
# Purpose: Ready-to-use image with Claude Code CLI (Node.js-based)
# Target Size: ~432MB (includes Node.js + npm)

FROM registry.access.redhat.com/ubi9/ubi-minimal:latest

LABEL maintainer="Super Platform Engineering"
LABEL description="UBI9-minimal with Claude Code CLI pre-installed"
LABEL version="1.0-claude-fixed"

# Install Node.js and required Coder agent utilities
# UBI9-minimal uses microdnf, so we need nodejs from AppStream
RUN microdnf install -y \
    nodejs \
    npm \
    tar \
    unzip \
    git \
    wget \
    findutils \
    && microdnf clean all \
    && rm -rf /var/cache/yum

# Create non-root user
RUN useradd -m -u 1000 -s /bin/bash coder

# Switch to coder user for npm install
USER coder
WORKDIR /home/coder

# Environment variables
#  Tells npm to install global packages into a folder the coder user actually owns
ENV NPM_CONFIG_PREFIX="/home/coder/.npm-global" \
    PATH="/home/coder/.npm-global/bin:${PATH}" \
    NODE_ENV=production

# Install Claude Code globally (as user)
ARG CLAUDE_CODE_VERSION=latest
RUN npm install -g @anthropic-ai/claude-code@${CLAUDE_CODE_VERSION}

# Bake PATH into shell init files so Coder agent startup scripts can find claude-code
# (Docker ENV is not inherited by shells spawned by the Coder agent init_script)
RUN echo 'export PATH="/home/coder/.npm-global/bin:$PATH"' >> /home/coder/.bashrc && \
    echo 'export NPM_CONFIG_PREFIX="/home/coder/.npm-global"' >> /home/coder/.bashrc

# Create workspace directory
RUN mkdir -p /home/coder/workspace

# Health check
HEALTHCHECK --interval=30s --timeout=3s \
    CMD claude-code --version || exit 1

CMD ["/bin/bash"]
